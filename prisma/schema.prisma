// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  BACKLOG
  SCHEDULED
  COMPLETED
}

enum RecurrenceType {
  DAILY
  WEEKDAYS
  WEEKLY
  MONTHLY
}

model User {
  id              String           @id @default(cuid())
  name            String?          @default("Default User")
  email           String?          @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  dayStartTime    String           @default("09:00") // HH:mm format
  dayEndTime      String           @default("17:00") // HH:mm format
  strictMode      Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tasks           Task[]
  recurringBlocks RecurringBlock[]
  recurringTasks  RecurringTask[]
  accounts        Account[]
  sessions        Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Task {
  id                String         @id @default(cuid())
  title             String
  duration          Int            // in minutes
  priority          Int            @default(2) // 1=High, 2=Medium, 3=Low
  deadline          DateTime?
  notes             String?
  status            TaskStatus     @default(BACKLOG)
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeBlocks        TimeBlock[]
  subtasks          Subtask[]
  recurringTaskId   String?        // source recurring task template
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId, status])
  @@index([deadline])
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId, order])
}

model RecurringBlock {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  startTime  String   // HH:mm format
  endTime    String   // HH:mm format
  daysOfWeek String   // comma-separated "0,1,2,3,4,5,6" (0=Monday)
  color      String?  // hex color
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model TimeBlock {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  isLocked  Boolean  @default(false)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([startTime, endTime])
}

model RecurringTask {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  duration       Int            // in minutes
  priority       Int            @default(2) // 1=High, 2=Medium, 3=Low
  notes          String?
  recurrenceType RecurrenceType
  recurrenceDays String?        // comma-separated 0-6 (0=Monday) — used for WEEKLY
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
}
